# thegamemage-theme
# Hugo + webpack + npm. static/styles.css, static/bundle.js, and static/fonts/
# are committed build outputs (Hugo serves them directly). public/ is the Hugo
# render output and is regenerated on every build. Global gitignore (~/.gitignore)
# handles .claude/ and .private-journal/.

# npm
node_modules/

# Hugo
/public/
/resources/_gen/
.hugo_build.lock

# Cloudflare Wrangler local state
.wrangler/

# Sass / build caches
.sass-cache/
*.css.map
*.scss.map
.npm
.eslintcache
.stylelintcache

# Logs
*.log
npm-debug.log*

# Environment / secrets
.env
.env.local
.env.*.local

# macOS
.DS_Store
._*
Icon[
]

# Claude Code (override global ~/.gitignore that ignores .claude/ entirely;
# track shared project config but keep personal settings local)
!.claude/
.claude/settings.local.json

# Test site.
/testsite/

# Ephemeral design-direction probes (raster + HTML scaffolding). Not durable
# artifacts; the confirmed shape brief in docs/ is the spec of record. Kept
# on-disk locally, never committed.
docs/preview/
